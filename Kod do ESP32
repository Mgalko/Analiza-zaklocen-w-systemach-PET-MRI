#include <Arduino.h>
#include <driver/ledc.h>
#include <driver/timer.h>

// --- KONFIGURACJA PINÓW (Zgodna ze schematem PCB) ---
#define PIN_DET1 21     // Wejście kanału 1 (Detektor A)
#define PIN_DET2 22     // Wejście kanału 2 (Detektor B)
#define PIN_LASER1 18   // Sterowanie laserem testowym 1
#define PIN_LASER2 19   // Sterowanie laserem testowym 2
#define PIN_COIL 25     // Wyjście PWM do sterownika cewki (MRI Gradient Model)

// --- PARAMETRY SYSTEMOWE ---
#define BUFFER_SIZE 256 // Rozmiar bufora (musi być potęgą 2 dla optymalizacji maskowania)
#define TIMER_GROUP TIMER_GROUP_0
#define TIMER_IDX   TIMER_0

// --- STRUKTURY DANYCH ---
struct Event {
    uint64_t ts; // Znacznik czasu w mikrosekundach
};

/**
 * Klasa EventBuffer: Implementacja bezblokadowego bufora kołowego.
 * Zaprojektowana do bezpiecznej komunikacji między przerwaniem (ISR) a pętlą główną.
 */
class EventBuffer {
public:
    volatile Event data[BUFFER_SIZE];
    volatile uint32_t head = 0; // Modyfikowane przez ISR
    volatile uint32_t tail = 0; // Modyfikowane przez loop()

    // Dodaje nowy znacznik czasu do bufora (wywoływane w ISR)
    void IRAM_ATTR push(uint64_t timestamp) {
        uint32_t next = (head + 1) & (BUFFER_SIZE - 1); // Szybkie modulo
        if (next != tail) { // Zabezpieczenie przed przepełnieniem
            data[head].ts = timestamp;
            head = next;
        }
    }
    
    // Zwraca liczbę elementów oczekujących na przetworzenie
    uint32_t count() {
        return (head - tail) & (BUFFER_SIZE - 1);
    }

    // Pobiera najstarszy znacznik czasu bez usuwania go
    uint64_t getTailTimestamp() {
        return data[tail].ts;
    }
};

// --- ZMIENNE GLOBALNE I STATYSTYKI ---
EventBuffer rbCh1, rbCh2;
uint32_t coinc_window = 10; // Szerokość okna koincydencji w [us]
bool sim_mode = false;      // Flaga trybu pracy (Realny vs Symulacja)

struct Stats {
    volatile uint32_t raw_ch1 = 0;     // Suma zliczeń kanału 1
    volatile uint32_t raw_ch2 = 0;     // Suma zliczeń kanału 2
    volatile uint32_t coincidences = 0; // Liczba wykrytych par (koincydencji)
} stats;

// --- A. WARSTWA AKWIZYCJI (INTERRUPT SERVICE ROUTINES) ---
// Funkcje wykonywane natychmiast po wykryciu impulsu przez sprzęt.

void IRAM_ATTR isr_ch1() {
    if (sim_mode) return; 
    uint64_t now;
    timer_get_counter_value(TIMER_GROUP, TIMER_IDX, &now); // Pobranie czasu z dokładnością 1us
    rbCh1.push(now);
    stats.raw_ch1++;
}

void IRAM_ATTR isr_ch2() {
    if (sim_mode) return;
    uint64_t now;
    timer_get_counter_value(TIMER_GROUP, TIMER_IDX, &now);
    rbCh2.push(now);
    stats.raw_ch2++;
}

// --- B. SILNIK KOINCYDENCJI (COINCIDENCE ENGINE) ---
/**
 * Analizuje bufory obu kanałów i szuka par zdarzeń, których różnica czasu
 * mieści się w zdefiniowanym oknie (coinc_window).
 */
void processCoincidences() {
    while (rbCh1.count() > 0 && rbCh2.count() > 0) {
        uint64_t t1 = rbCh1.getTailTimestamp();
        uint64_t t2 = rbCh2.getTailTimestamp();

        int64_t diff = (int64_t)(t1 - t2);

        // Sprawdzenie warunku koincydencji: |t1 - t2| <= delta_t
        if (abs(diff) <= (int64_t)coinc_window) {
            stats.coincidences++;
            // Usuń oba zdarzenia z buforów (zostały sparowane)
            rbCh1.tail = (rbCh1.tail + 1) & (BUFFER_SIZE - 1);
            rbCh2.tail = (rbCh2.tail + 1) & (BUFFER_SIZE - 1);
        } 
        else if (t1 < t2) {
            // Zdarzenie t1 jest zbyt stare, by znaleźć parę - usuń
            rbCh1.tail = (rbCh1.tail + 1) & (BUFFER_SIZE - 1);
        } 
        else {
            // Zdarzenie t2 jest zbyt stare - usuń
            rbCh2.tail = (rbCh2.tail + 1) & (BUFFER_SIZE - 1);
        }
    }
}

// --- C. WARSTWA SYMULACJI STOCHASTYCZNEJ (MONTE CARLO) ---
/**
 * Generuje sztuczne zdarzenia naśladujące fizykę PET:
 * - lambda_true: Prawdziwe anihilacje (koincydencje)
 * - lambda_rand: Zliczenia przypadkowe (tło/szum)
 * - jitter: Niepewność czasowa detektora
 */
void runSimulation() {
    static uint32_t last_sim = 0;
    if (micros() - last_sim < 500) return; // Częstotliwość próbkowania symulacji
    last_sim = micros();

    uint64_t now;
    timer_get_counter_value(TIMER_GROUP, TIMER_IDX, &now);

    const float lambda_true = 0.05;   // Prawdopodobieństwo koincydencji
    const float lambda_rand = 0.10;   // Prawdopodobieństwo szumu
    const float scatter_prob = 0.2;   // Prawdopodobieństwo rozproszenia (opóźnienie sygnału)
    const float efficiency = 0.8;     // Wydajność kwantowa detektora
    const uint32_t dead_time = 10;    // Czas martwy elektroniki [us]

    static uint64_t last_hit_ch1 = 0;
    static uint64_t last_hit_ch2 = 0;

    // 1. Symulacja prawdziwej anihilacji (Para fotonów)
    if (random(0, 1000) < lambda_true * 1000) {
        if (random(0,1000) < efficiency*1000) {
            if (now - last_hit_ch1 > dead_time) {
                rbCh1.push(now);
                stats.raw_ch1++;
                last_hit_ch1 = now;
            }
        }
        
        // Dodanie jittera czasowego i efektu scatter
        int jitter = random(-3, 4);
        uint64_t t2 = now + jitter;
        if (random(0,1000) < scatter_prob * 1000) t2 += random(5, 20);

        if (random(0,1000) < efficiency*1000) {
            if (t2 - last_hit_ch2 > dead_time) {
                rbCh2.push(t2);
                stats.raw_ch2++;
                last_hit_ch2 = t2;
            }
        }
    }

    // 2. Symulacja zliczeń przypadkowych (Randoms)
    if (random(0,1000) < lambda_rand * 1000) {
        if (now - last_hit_ch1 > dead_time) {
            rbCh1.push(now);
            stats.raw_ch1++;
            last_hit_ch1 = now;
        }
    }
    if (random(0,1000) < lambda_rand * 1000) {
        if (now - last_hit_ch2 > dead_time) {
            rbCh2.push(now);
            stats.raw_ch2++;
            last_hit_ch2 = now;
        }
    }
}

// --- D. KOMUNIKACJA SZEREGOWA (UART) ---
void handleSerial() {
    if (Serial.available()) {
        String cmd = Serial.readStringUntil('\n');
        cmd.trim();
        
        if (cmd.equals("mode sim")) { 
            sim_mode = true; 
            Serial.println("# Tryb: Symulacja Monte Carlo AKTYWNY"); 
        }
        else if (cmd.equals("mode real")) { 
            sim_mode = false; 
            Serial.println("# Tryb: Pomiar Rzeczywisty AKTYWNY"); 
        }
        else if (cmd.equals("reset")) {
            stats.raw_ch1 = 0;
            stats.raw_ch2 = 0;
            stats.coincidences = 0;
            Serial.println("# Statystyki wyzerowane");
        }
    }
}

/**
 * Wysyła dane w formacie CSV do komputera w celu wizualizacji (Python/Julia).
 */
void broadcastData() {
    static uint32_t last_print = 0;
    if (millis() - last_print < 40) return; // Odświeżanie ~25 Hz
    last_print = millis();

    uint64_t now_ts;
    timer_get_counter_value(TIMER_GROUP, TIMER_IDX, &now_ts);

    // FORMAT: timestamp_us, raw_ch1, raw_ch2, coincidences
    Serial.print(now_ts);
    Serial.print(",");
    Serial.print(stats.raw_ch1);
    Serial.print(",");
    Serial.print(stats.raw_ch2);
    Serial.print(",");
    Serial.println(stats.coincidences);
}

// --- E. INICJALIZACJA SYSTEMU ---
void setup() {
    Serial.begin(115200);

    // Konfiguracja sprzętowego Timera (80MHz / 80 = 1MHz -> 1 tick = 1us)
    timer_config_t config = {
        .alarm_en = TIMER_ALARM_DIS,
        .counter_en = TIMER_PAUSE,
        .intr_type = TIMER_INTR_LEVEL,
        .counter_dir = TIMER_COUNT_UP,
        .auto_reload = TIMER_AUTORELOAD_DIS,
        .divider = 80 
    };
    timer_init(TIMER_GROUP, TIMER_IDX, &config);
    timer_set_counter_value(TIMER_GROUP, TIMER_IDX, 0);
    timer_start(TIMER_GROUP, TIMER_IDX);

    // Konfiguracja wejść/wyjść
    pinMode(PIN_DET1, INPUT_PULLUP);
    pinMode(PIN_DET2, INPUT_PULLUP);
    pinMode(PIN_LASER1, OUTPUT);
    pinMode(PIN_LASER2, OUTPUT);
    
    // Podpięcie przerw pod zbocze narastające (detekcja impulsu)
    attachInterrupt(digitalPinToInterrupt(PIN_DET1), isr_ch1, RISING);
    attachInterrupt(digitalPinToInterrupt(PIN_DET2), isr_ch2, RISING);

    // Konfiguracja PWM dla cewki (Modelowanie pola MRI)
    ledcSetup(0, 1000, 8); // Kanał 0, 1kHz, 8-bit rozdzielczości
    ledcAttachPin(PIN_COIL, 0);
    ledcWrite(0, 128); // 50% wypełnienia na start

    Serial.println("# System PET DAQ Ready. Format: ts,ch1,ch2,coinc");
}

// --- F. PĘTLA GŁÓWNA ---
void loop() {
    if (sim_mode) {
        runSimulation();
    }
    
    processCoincidences(); // Przetwarzaj bufory w wolnym czasie procesora
    handleSerial();        // Obsługa komend użytkownika
    broadcastData();       // Transmisja danych do GUI
}
